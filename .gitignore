# Root .gitignore

# Environment variables
.env
.env.local
.env.*.local
.env.production

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Production
build/
dist/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# OS
Thumbs.db
.thumbs.db

# Temporary files
*.tmp
*.temp
.cache/

# Logs
logs/
*.log

# Package manager locks (optional - uncomment to include)
# package-lock.json
# yarn.lock

# Testing
coverage/
.nyc_output/

# Misc
.prettierignore
*.orig
